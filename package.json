{
  "name": "interstate-septic-manager",
  "version": "0.1.0",
  "description": "All-in-one business management for septic & sewer companies",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.interstateseptic.manager",
    "productName": "Interstate Septic Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "supabase.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@supabase/supabase-js": "^2.49.0",
    "bcryptjs": "^3.0.3",
    "nodemailer": "^8.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  }
}
